# This .gitignore file is for a Unity project.
#
# Original Source for the Unity gitignore is available at:
# https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# Memory-capturing-related
/[Mm]emoryCaptures/

# Asset Compute Cache
/.utmp/

# Cardboard XR Plugin
/Assets/Plugins/Android/cardboard.aar
/Assets/Plugins/Android/cardboard.meta

# Build Artifacts
Android_BurstDebugInformation_DoNotShip/
apk_BackUpThisFolder_ButDontShipItWithYourGame/

# IDE files
.vs/
.vscode/
.vsconfig
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.unityproj
*.booproj

# OS-specific
.DS_Store
Thumbs.db

# Unity-generated
[Rr]ecordings/
[Aa]ssetStoreTools*

# Crashlytics/Firebase
Firebase/m2repository

# Keystore files (KEEP THEM PRIVATE)
*.keystore
*.jks
user.keystore
